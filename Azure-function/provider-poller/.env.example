# Copy this file to .env and fill in your own values.
ENVIRONMENT=production
GRAFANA_URL=https://your-grafana-url.example
GRAFANA_TOKEN=your_grafana_token
GRAFANA_PROM_UID=your_prometheus_uid
INSTATUS_API_KEY=your_instatus_api_key
INSTATUS_PAGE_ID=your_instatus_page_id
INSTATUS_BASE=https://api.instatus.com/v2

# Provider component IDs
INSTATUS_COMP_ANTHROPIC=your_component_id
INSTATUS_COMP_OPENAI=your_component_id
INSTATUS_COMP_GEMINI=your_component_id
INSTATUS_COMP_DEEPGRAM=your_component_id
INSTATUS_COMP_VAPI=your_component_id
INSTATUS_COMP_COMPOSIO=your_component_id
INSTATUS_COMP_TWILIO=your_component_id

# Service component IDs
INSTATUS_SVC_AIOS_PRODUCTION=your_component_id
INSTATUS_SVC_BACKEND_API=your_component_id
INSTATUS_SVC_N8N=your_component_id
INSTATUS_SVC_TRIEVE_KB=your_component_id
INSTATUS_SVC_CELERY=your_component_id